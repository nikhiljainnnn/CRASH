{
    "include": [
        "models",
        "scripts",
        "api",
        "inference",
        "training",
        "deployment"
    ],
    "exclude": [
        "Datasets",
        "data",
        "checkpoints",
        "runs",
        "**/node_modules",
        "**/__pycache__"
    ],
    "extraPaths": [
        "."
    ],
    "pythonVersion": "3.10",
    "pythonPlatform": "Windows",
    "reportMissingImports": "warning",
    "reportMissingModuleSource": "none",
    "reportOptionalMemberAccess": "none",
    "typeCheckingMode": "basic"
}
